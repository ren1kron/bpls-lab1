    <bpmn:userTask id="Activity_17kbayu" name="Повторить попытку оплаты или отменить?">
      <bpmn:incoming>Flow_0mqgsz6</bpmn:incoming>
      <bpmn:outgoing>Flow_126oxq5</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_01" sourceRef="StartEvent_CreateCampaign" targetRef="UserTask_CreateDraft" />
    <bpmn:sequenceFlow id="Flow_05" sourceRef="UserTask_CreateDraft" targetRef="UserTask_ConfigureCampaign" />
