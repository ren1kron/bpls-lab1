      <bpmn:outgoing>Flow_0u8941y</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:intermediateCatchEvent id="IntermediateMessage_PauseRequested" name="Запрошена пауза">
      <bpmn:messageEventDefinition messageRef="Message_PauseRequested" />
    </bpmn:intermediateCatchEvent>
    <bpmn:eventBasedGateway id="EventBasedGateway_WaitEndSignal" name="Ожидание условия завершения" />
    <bpmn:intermediateCatchEvent id="IntermediateTimer_EndAt" name="Достигнуто endAt">
      <bpmn:timerEventDefinition>
        <bpmn:timeDate xsi:type="bpmn:tFormalExpression">${endAt}</bpmn:timeDate>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="IntermediateMessage_BudgetExhausted" name="Бюджет исчерпан">
      <bpmn:messageEventDefinition messageRef="Message_BudgetExhausted" />
    </bpmn:intermediateCatchEvent>
    <bpmn:serviceTask id="ServiceTask_PauseCampaign" name="Поставить на паузу" />
    <bpmn:serviceTask id="ServiceTask_StopCampaign" name="Остановить кампанию" />
    <bpmn:endEvent id="EndEvent_CampaignFinished" name="Завершение">
      <bpmn:incoming>Flow_0kgu25i</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="ServiceTask_ActivateCampaign" name="Активировать кампанию (публикация)">
      <bpmn:incoming>Flow_1du989t</bpmn:incoming>
    </bpmn:serviceTask>
    <bpmn:intermediateCatchEvent id="IntermediateTimer_WaitStart" name="Ожидание времени старта (startAt)">
