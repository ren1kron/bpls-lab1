      <bpmn:outgoing>Flow_0gpfg6c</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="UserTask_ManualModeration" name="Ручная модерация">
      <bpmn:incoming>Flow_0gpfg6c</bpmn:incoming>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_ModerationApproved" name="Одобрено?" />
    <bpmn:userTask id="UserTask_FixAfterRejection" name="Доработать по замечаниям модератора" />
    <bpmn:userTask id="Activity_191l1ni" name="Оплатить">
