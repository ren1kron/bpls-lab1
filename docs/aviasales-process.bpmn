    <bpmn:sequenceFlow id="Flow_09" sourceRef="UserTask_ManualModeration" targetRef="Gateway_ModerationApproved" />
    <bpmn:sequenceFlow id="Flow_10_OK" sourceRef="Gateway_ModerationApproved" targetRef="Activity_02zbr4x">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${moderationApproved == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_10_REJECT" sourceRef="Gateway_ModerationApproved" targetRef="UserTask_FixAfterRejection">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${moderationApproved == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0u8941y" sourceRef="Activity_02zbr4x" targetRef="Activity_191l1ni" />
    <bpmn:sequenceFlow id="Flow_1i7cs46" sourceRef="Gateway_1szdbtx" targetRef="Activity_02zbr4x" />
