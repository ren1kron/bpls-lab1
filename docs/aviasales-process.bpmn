    <bpmn:sequenceFlow id="Flow_26_STOP" sourceRef="Gateway_ResumeOrStop" targetRef="ServiceTask_StopCampaign">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${resume == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_28_END" sourceRef="ServiceTask_StopCampaign" targetRef="EndEvent_CampaignFinished" />
